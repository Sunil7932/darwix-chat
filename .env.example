# Copy to `.env` and fill in. `.env` is git-ignored — never commit your key.

# Server-side only. Read by the /api/chat proxy; never exposed to the browser.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional. Defaults to claude-opus-4-8. For faster / cheaper replies, set e.g.
# claude-haiku-4-5 or claude-sonnet-4-6.
ANTHROPIC_MODEL=claude-opus-4-8
