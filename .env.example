# Copy to `.env` and fill in. `.env` is git-ignored — never commit your key.

# Server-side only. Read by the /api/chat proxy; never exposed to the browser.
# Get a FREE key (no credit card) at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional. Defaults to gemini-2.0-flash (fast and free-tier friendly).
# Other options: gemini-2.5-flash, gemini-1.5-flash.
GEMINI_MODEL=gemini-2.0-flash
